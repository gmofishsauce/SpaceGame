# ── Go ──────────────────────────────────────────────────────────────────────
# Compiled binaries
spacegame
spacegame.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary and coverage output
*.test
*.out
coverage.html

# Vendor directory (not used here, but common)
vendor/

# Go workspace sum file (go.work itself may be committed, sum is generated)
go.work.sum

# ── Node / Vite ──────────────────────────────────────────────────────────────
# Dependencies
node_modules/

# Build output — web/dist/ is regenerated by `cd web && npm run build`.
# Keep web/dist/index.html (placeholder that makes //go:embed compile without npm).
web/dist/*
!web/dist/index.html

# proto/dist/ is regenerated by `cd proto && npm run build`
proto/dist/

# npm / yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Local environment files
.env
.env.local
.env.*.local

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
