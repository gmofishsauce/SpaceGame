# ── Go ──────────────────────────────────────────────────────────────────────
# Compiled binaries
/spacegame
/spacegame.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary and coverage output
*.test
*.out
coverage.html

# Vendor directory (not used here, but common)
vendor/

# Go workspace sum file (go.work itself may be committed, sum is generated)
go.work.sum

# ── Node / Vite ──────────────────────────────────────────────────────────────
# Dependencies
node_modules/

# web/dist/ is the compiled frontend. Run scripts/build-frontend.sh to
# regenerate it, then commit the result so `go build` embeds the assets
# without requiring npm on the build machine.
# node_modules is never committed.
web/node_modules/

# proto/dist/ is regenerated by `cd proto && npm run build`
proto/dist/

# npm / yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Local environment files
.env
.env.local
.env.*.local

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
